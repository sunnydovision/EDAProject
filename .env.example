# Copy thành .env và điền giá trị thật. Không commit file .env.

# Bắt buộc: API key (OpenAI)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# --- Lỗi 429 "Rate limit reached" (sau khi nạp tiền vẫn gặp) ---
# Lỗi đó là giới hạn token/phút (TPM), không phải hết tiền. Model gpt-5-nano thường có TPM thấp.
# Cách 1: Đợi đến khi TPM reset (thời gian trong thông báo lỗi).
# Cách 2: Chuyển sang Chat Completions + model có TPM cao hơn (ví dụ gpt-4o-mini):
# OPENAI_USE_RESPONSES_API=0
# QUGEN_LLM_MODEL=gpt-4o-mini

# Dùng Responses API (client.responses.create). 1=yes, 0=Chat Completions
# OPENAI_USE_RESPONSES_API=1

# Model: gpt-5-nano (Responses API) hoặc gpt-4o-mini (Chat Completions)
# QUGEN_LLM_MODEL=gpt-5-nano

# Nếu dùng endpoint khác OpenAI (Groq, Together, Ollama...) thì set và dùng OPENAI_USE_RESPONSES_API=0
# OPENAI_API_BASE=https://api.groq.com/openai/v1
